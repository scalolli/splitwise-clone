<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{statusCode}} — Simply Split It</title>
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
    <nav>
        <a href="/" class="brand">Simply Split It</a>
        <span class="spacer"></span>
    </nav>

    <div class="page">
        <div class="card" style="text-align: center; padding: 3rem 2rem;">
            <h1 style="font-size: 3rem; color: var(--color-text-muted); margin-bottom: 0.5rem;">{{statusCode}}</h1>
            <p style="color: var(--color-text-secondary); margin-bottom: 1.5rem;">{{message}}</p>
            <a href="/" class="btn">Go back home</a>
        </div>
    </div>
</body>
</html>
