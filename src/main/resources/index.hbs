<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Splitwise</title>
</head>
<body>
    <h1>Splitwise</h1>
    <nav>
        <a href="/">Home</a> |
        <form method="post" action="/logout" style="display:inline">
            <button type="submit">Logout</button>
        </form>
    </nav>

    <h2>Groups</h2>
    {{#if groups}}
    <ul>
        {{#each groups}}
        <li><a href="/group/{{id}}">{{name}}</a></li>
        {{/each}}
    </ul>
    {{else}}
    <p>No groups yet.</p>
    {{/if}}
</body>
</html>
