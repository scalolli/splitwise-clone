<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Splitwise</title>
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
    <nav>
        <a href="/">Splitwise</a>
        <a href="/group/create">New Group</a>
        <form method="post" action="/logout" style="display:inline">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit">Logout</button>
        </form>
    </nav>

    <div class="page">
        <h1>Your Groups</h1>

        {{#if groups}}
        <ul>
            {{#each groups}}
            <li><a href="/group/{{id}}">{{name}}</a></li>
            {{/each}}
        </ul>
        {{else}}
        <p class="muted">No groups yet. <a href="/group/create">Create one</a>.</p>
        {{/if}}
    </div>
</body>
</html>
