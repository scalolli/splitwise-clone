<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Splitwise</title>
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
    <nav>
        <a href="/" class="brand">Splitwise</a>
        <a href="/group/create">New Group</a>
        <span class="spacer"></span>
        <form method="post" action="/logout">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit" class="nav-logout">Logout</button>
        </form>
    </nav>

    <div class="page">
        <div class="page-header">
            <h1>Your Groups</h1>
            <a href="/group/create" class="btn btn-outline">New Group</a>
        </div>

        {{#if groups}}
        <ul class="group-list">
            {{#each groups}}
            <li><a href="/group/{{id}}">{{name}}</a></li>
            {{/each}}
        </ul>
        {{else}}
        <div class="empty-state">
            <p>No groups yet. <a href="/group/create">Create your first group</a>.</p>
        </div>
        {{/if}}
    </div>
</body>
</html>
