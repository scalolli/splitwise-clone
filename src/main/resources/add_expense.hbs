<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Add Expense — Splitwise</title>
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
    <nav>
        <a href="/">Splitwise</a>
        <a href="/group/{{groupId}}">Back to Group</a>
        <form method="post" action="/logout" style="display:inline">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit">Logout</button>
        </form>
    </nav>

    <div class="page">
        <h1>Add Expense</h1>

        {{#if errors}}
        <ul class="errors">
            {{#each errors}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}

        <form method="post" action="/group/{{groupId}}/add_expense">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">

            <label><span>Description</span>
                <input type="text" name="description" value="{{description}}" required>
            </label>

            <label><span>Amount</span>
                <input type="text" name="amount" value="{{amount}}" required placeholder="0.00">
            </label>

            <label><span>Date</span>
                <input type="date" name="incurred_at" value="{{incurredAt}}">
            </label>

            <label><span>Paid by</span>
                <select name="payer_id">
                    {{#each members}}
                    <option value="{{id}}">{{username}}</option>
                    {{/each}}
                </select>
            </label>

            <h3 style="margin-top: 1.25rem; margin-bottom: 0.5rem;">Splits</h3>
            {{#each members}}
            <label>
                <span>{{username}}</span>
                <input type="hidden" name="split_user_id" value="{{id}}">
                <input type="text" name="split_amount" value="0.00" placeholder="0.00">
            </label>
            {{/each}}

            <button type="submit">Add Expense</button>
        </form>
    </div>
</body>
</html>
