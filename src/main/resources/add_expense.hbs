<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Add Expense — Splitwise</title>
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
    <nav>
        <a href="/" class="brand">Splitwise</a>
        <a href="/group/{{groupId}}">Back to Group</a>
        <span class="spacer"></span>
        <form method="post" action="/logout">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit" class="nav-logout">Logout</button>
        </form>
    </nav>

    <div class="page">
        <h1>Add Expense</h1>

        {{#if errors}}
        <ul class="errors">
            {{#each errors}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}

        <div class="card">
            <form method="post" action="/group/{{groupId}}/add_expense">
                <input type="hidden" name="_csrf" value="{{csrfToken}}">

                <label><span>Description</span>
                    <input type="text" name="description" value="{{description}}" required>
                </label>

                <label><span>Amount</span>
                    <input type="text" name="amount" value="{{amount}}" required placeholder="0.00">
                </label>

                <label><span>Date</span>
                    <input type="date" name="incurred_at" value="{{incurredAt}}">
                </label>

                <label><span>Paid by</span>
                    <select name="payer_id">
                        {{#each members}}
                        <option value="{{id}}">{{username}}</option>
                        {{/each}}
                    </select>
                </label>

                <div class="btn-row">
                    <button type="submit">Add Expense</button>
                    <a href="/group/{{groupId}}" class="btn btn-ghost">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
