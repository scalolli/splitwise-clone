<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Edit Expense — Splitwise</title>
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
    <nav>
        <a href="/">Splitwise</a>
        <a href="/group/{{groupId}}">Back to Group</a>
        <form method="post" action="/logout" style="display:inline">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit">Logout</button>
        </form>
    </nav>

    <div class="page">
        <h1>Edit Expense</h1>

        {{#if errors}}
        <ul class="errors">
            {{#each errors}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}

        <form method="post" action="/expenses/{{expenseId}}/edit">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">

            <label><span>Description</span>
                <input type="text" name="description" value="{{description}}" required>
            </label>

            <label><span>Amount</span>
                <input type="text" name="amount" value="{{amount}}" required placeholder="0.00">
            </label>

            <label><span>Date</span>
                <input type="date" name="incurred_at" value="{{incurredAt}}">
            </label>

            <label><span>Paid by</span>
                <select name="payer_id">
                    {{#each members}}
                    <option value="{{id}}">{{username}}</option>
                    {{/each}}
                </select>
            </label>

            <button type="submit">Save Changes</button>
        </form>

        <hr style="margin: 2rem 0; border-color: #e0e0e0;">

        <form method="post" action="/expenses/{{expenseId}}/delete" onsubmit="return confirm('Delete this expense?')">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit" class="destructive">Delete Expense</button>
        </form>
    </div>
</body>
</html>
