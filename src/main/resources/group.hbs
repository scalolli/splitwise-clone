<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{groupName}} — Splitwise</title>
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
    <nav>
        <a href="/" class="brand">Splitwise</a>
        <a href="/">Home</a>
        <a href="/group/{{groupId}}/add_expense">Add Expense</a>
        <a href="/group/{{groupId}}/edit">Edit Group</a>
        <a href="/group/{{groupId}}/import">Import CSV</a>
        <span class="spacer"></span>
        <form method="post" action="/logout">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit" class="nav-logout">Logout</button>
        </form>
    </nav>

    <div class="page">
        <div class="page-header">
            <h1>{{groupName}}</h1>
            <a href="/group/{{groupId}}/add_expense" class="btn">Add Expense</a>
        </div>

        {{#if flash}}
        <div class="flash">{{flash}}</div>
        {{/if}}

        <p class="section-label">Members</p>
        <div class="card">
            {{#if members}}
            <ul class="members">
                {{#each members}}<li>{{username}}</li>{{/each}}
            </ul>
            {{else}}
            <p class="muted">No members.</p>
            {{/if}}
        </div>

        <p class="section-label">Expenses</p>
        {{#if expenses}}
        <form method="post" action="/group/{{groupId}}/expenses/delete">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            {{#if isOwner}}<th style="width:2.5rem"></th>{{/if}}
                            <th>Date</th>
                            <th>Description</th>
                            <th>Amount</th>
                            <th>Paid by</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each expenses}}
                        <tr>
                            {{#if ../isOwner}}<td><input type="checkbox" name="expense_id" value="{{id}}"></td>{{/if}}
                            <td class="muted">{{incurredAt}}</td>
                            <td>{{description}}</td>
                            <td><strong>{{amount}}</strong></td>
                            <td>{{payer}}</td>
                            <td><a href="/expenses/{{id}}/edit">Edit</a></td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            {{#if isOwner}}
            <div class="btn-row">
                <button type="submit" class="btn-destructive">Delete selected</button>
            </div>
            {{/if}}
        </form>
        {{else}}
        <div class="card">
            <div class="empty-state">
                <p>No expenses yet. <a href="/group/{{groupId}}/add_expense">Add the first one</a>.</p>
            </div>
        </div>
        {{/if}}

        <p class="section-label">Balances</p>
        <div class="card">
            {{#if balances}}
            <ul class="balances">
                {{#each balances}}<li>{{debtor}} owes {{creditor}} <strong>{{amount}}</strong></li>{{/each}}
            </ul>
            {{else}}
            <span class="settled-badge">All settled up!</span>
            {{/if}}
        </div>

        <p class="section-label">Record Settlement</p>
        <div class="card">
            {{#if settlementErrors}}
            <ul class="errors">
                {{#each settlementErrors}}<li>{{this}}</li>{{/each}}
            </ul>
            {{/if}}
            <form method="post" action="/group/{{groupId}}/settle">
                <input type="hidden" name="_csrf" value="{{csrfToken}}">
                <label><span>From</span>
                    <select name="from_user_id">
                        {{#each members}}<option value="{{id}}">{{username}}</option>{{/each}}
                    </select>
                </label>
                <label><span>To</span>
                    <select name="to_user_id">
                        {{#each members}}<option value="{{id}}">{{username}}</option>{{/each}}
                    </select>
                </label>
                <label><span>Amount</span>
                    <input type="text" name="amount" placeholder="0.00">
                </label>
                <div class="btn-row">
                    <button type="submit">Record Settlement</button>
                </div>
            </form>
        </div>

        <p class="section-label">Settlement History</p>
        <div class="card">
            {{#if settlements}}
            <ul class="settlements">
                {{#each settlements}}<li>{{from}} paid {{to}} <strong>{{amount}}</strong></li>{{/each}}
            </ul>
            {{else}}
            <p class="muted">No settlements recorded yet.</p>
            {{/if}}
        </div>
    </div>
</body>
</html>
