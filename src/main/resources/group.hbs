<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{groupName}} — Splitwise</title>
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
    <nav>
        <a href="/">Splitwise</a>
        <a href="/">Home</a>
        <a href="/group/{{groupId}}/edit">Edit Group</a>
        <a href="/group/{{groupId}}/add_expense">Add Expense</a>
        <a href="/group/{{groupId}}/import">Import from CSV</a>
        <form method="post" action="/logout" style="display:inline">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit">Logout</button>
        </form>
    </nav>

    <div class="page">
        <h1>{{groupName}}</h1>

        <h2>Members</h2>
        {{#if members}}
        <ul>
            {{#each members}}<li>{{username}}</li>{{/each}}
        </ul>
        {{else}}
        <p class="muted">No members.</p>
        {{/if}}

        <h2>Expenses</h2>
        {{#if expenses}}
        <form method="post" action="/group/{{groupId}}/expenses/delete">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <table>
                <thead>
                    <tr>
                        {{#if isOwner}}<th></th>{{/if}}
                        <th>Date</th>
                        <th>Description</th>
                        <th>Amount</th>
                        <th>Paid by</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {{#each expenses}}
                    <tr>
                        {{#if ../isOwner}}<td><input type="checkbox" name="expense_id" value="{{id}}"></td>{{/if}}
                        <td>{{incurredAt}}</td>
                        <td>{{description}}</td>
                        <td>{{amount}}</td>
                        <td>{{payer}}</td>
                        <td><a href="/expenses/{{id}}/edit">Edit</a></td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            {{#if isOwner}}
            <button type="submit">Delete selected</button>
            {{/if}}
        </form>
        {{else}}
        <p class="muted">No expenses yet. <a href="/group/{{groupId}}/add_expense">Add one</a>.</p>
        {{/if}}

        <h2>Balances</h2>
        {{#if balances}}
        <ul class="balances">
            {{#each balances}}<li>{{debtor}} owes {{creditor}} {{amount}}</li>{{/each}}
        </ul>
        {{else}}
        <p>All settled up!</p>
        {{/if}}

        <h2>Record Settlement</h2>
        {{#if settlementErrors}}
        <ul class="errors">
            {{#each settlementErrors}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}
        <form method="post" action="/group/{{groupId}}/settle">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <label><span>From</span>
                <select name="from_user_id">
                    {{#each members}}<option value="{{id}}">{{username}}</option>{{/each}}
                </select>
            </label>
            <label><span>To</span>
                <select name="to_user_id">
                    {{#each members}}<option value="{{id}}">{{username}}</option>{{/each}}
                </select>
            </label>
            <label><span>Amount</span>
                <input type="text" name="amount" placeholder="0.00">
            </label>
            <button type="submit">Record Settlement</button>
        </form>

        <h2>Settlement History</h2>
        {{#if settlements}}
        <ul class="settlements">
            {{#each settlements}}<li>{{from}} paid {{to}} {{amount}}</li>{{/each}}
        </ul>
        {{else}}
        <p class="muted">No settlements yet.</p>
        {{/if}}
    </div>
</body>
</html>
