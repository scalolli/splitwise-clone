<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Edit Group — Simply Split It</title>
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
    <nav>
        <a href="/" class="brand">Simply Split It</a>
        <a href="/group/{{groupId}}">Back to Group</a>
        <span class="spacer"></span>
        <form method="post" action="/logout">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit" class="nav-logout">Logout</button>
        </form>
    </nav>

    <div class="page">
        <h1>Edit Group</h1>

        {{#if errors}}
        <ul class="errors">
            {{#each errors}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}

        <p class="section-label">Group Name</p>
        <div class="card">
            <form method="post" action="/group/{{groupId}}/edit">
                <input type="hidden" name="_csrf" value="{{csrfToken}}">
                <label><span>Name</span>
                    <input type="text" name="name" value="{{groupName}}" required>
                </label>
                <div class="btn-row">
                    <button type="submit">Save Changes</button>
                    <a href="/group/{{groupId}}" class="btn btn-ghost">Cancel</a>
                </div>
            </form>
        </div>

        <p class="section-label">Members</p>
        <div class="card">
            <ul>
                {{#each members}}
                <li style="display:flex; align-items:center; justify-content:space-between;">
                    <span>{{username}}</span>
                    <form method="post" action="/group/{{../groupId}}/remove_member/{{id}}">
                        <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                        <button type="submit" class="btn btn-ghost" style="padding: 0.2rem 0.6rem; font-size: 0.8rem; color: var(--color-destructive); border-color: var(--color-destructive);">Remove</button>
                    </form>
                </li>
                {{/each}}
            </ul>
        </div>

        <p class="section-label">Add Member</p>
        <div class="card">
            <form method="post" action="/group/{{groupId}}/add_member">
                <input type="hidden" name="_csrf" value="{{csrfToken}}">
                <label><span>Username</span>
                    <input type="text" name="username" required>
                </label>
                <div class="btn-row">
                    <button type="submit">Add Member</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
