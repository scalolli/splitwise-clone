<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Edit Group — Splitwise</title>
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
    <nav>
        <a href="/">Splitwise</a>
        <a href="/group/{{groupId}}">Back to Group</a>
        <form method="post" action="/logout" style="display:inline">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit">Logout</button>
        </form>
    </nav>

    <div class="page">
        <h1>Edit Group</h1>

        {{#if errors}}
        <ul class="errors">
            {{#each errors}}<li>{{this}}</li>{{/each}}
        </ul>
        {{/if}}

        <form method="post" action="/group/{{groupId}}/edit">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <label><span>Group Name</span>
                <input type="text" name="name" value="{{groupName}}" required>
            </label>
            <button type="submit">Save Changes</button>
        </form>

        <h2>Members</h2>
        <ul>
            {{#each members}}
            <li>
                {{username}}
                <form method="post" action="/group/{{../groupId}}/remove_member/{{id}}" style="display:inline; margin-left: 0.5rem">
                    <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                    <button type="submit" class="destructive" style="padding: 0.15rem 0.6rem; font-size: 0.8rem;">Remove</button>
                </form>
            </li>
            {{/each}}
        </ul>

        <h2>Add Member</h2>
        <form method="post" action="/group/{{groupId}}/add_member">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <label><span>Username</span>
                <input type="text" name="username" required>
            </label>
            <button type="submit">Add Member</button>
        </form>
    </div>
</body>
</html>
